# ----- Discord Application -----
# À récupérer sur https://discord.com/developers/applications
DISCORD_CLIENT_ID=ton_client_id
DISCORD_CLIENT_SECRET=ton_client_secret_oauth2
DISCORD_BOT_TOKEN=ton_bot_token

# ID de ton serveur Discord (clic droit sur le serveur > Copier l'identifiant)
DISCORD_GUILD_ID=ton_guild_id

# ----- Application -----
# URL publique du site (sans slash final).
# En local : http://localhost:3000
# En prod (domaine perso) : https://ton-domaine.com
# Sur Railway : laisse VIDE → l'URL publique est détectée automatiquement
#               via RAILWAY_PUBLIC_DOMAIN. Renseigne-la seulement si tu
#               utilises un domaine personnalisé.
BASE_URL=http://localhost:3000

# Port d'écoute du serveur.
# En local : 3000. Sur Railway : NE PAS définir, la plateforme l'injecte.
PORT=3000

# Secret pour signer les cookies de session (mets une longue chaîne aléatoire)
SESSION_SECRET=change_moi_par_une_longue_chaine_aleatoire
